{
	"name": "aguia-gestao",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"packageManager": "pnpm@9.12.2",
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"lint": "eslint --ext .ts,.tsx src",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"server": "node ./server/index.mjs",
		"lan:start": "pnpm build && pnpm server",
		"win:backup-now": "powershell -ExecutionPolicy Bypass -File ./scripts/windows/backup-db.ps1",
		"win:install-startup": "powershell -ExecutionPolicy Bypass -File ./scripts/windows/install-startup-task.ps1",
		"win:install-backup-task": "powershell -ExecutionPolicy Bypass -File ./scripts/windows/install-backup-task.ps1",
		"win:package": "powershell -ExecutionPolicy Bypass -File ./scripts/windows/create-portable-package.ps1"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.56.0",
		"cors": "^2.8.5",
		"dexie": "^4.0.8",
		"express": "^4.21.2",
		"jsencrypt": "^3.3.2",
		"jspdf": "^4.2.1",
		"jspdf-autotable": "^5.0.7",
		"lucide-react": "^0.357.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"zod": "^3.24.0",
		"zustand": "^4.5.4"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.7.4",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.0",
		"@typescript-eslint/eslint-plugin": "^8.11.0",
		"@typescript-eslint/parser": "^8.11.0",
		"@vitejs/plugin-react": "^5.1.6",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.14.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.11",
		"jsdom": "^29.0.1",
		"postcss": "^8.4.47",
		"prettier": "^3.3.3",
		"tailwindcss": "^3.4.13",
		"typescript": "^5.6.3",
		"vite": "^5.4.9",
		"vitest": "^2.1.5"
	}
}